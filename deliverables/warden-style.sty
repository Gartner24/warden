    \color{white}\sffamily\bfseries Verificación \\
  \endfirsthead
    \rowcolor{wardendark}
    \color{white}\sffamily\bfseries ID &
    \color{white}\sffamily\bfseries Categoría &
    \color{white}\sffamily\bfseries Requerimiento &
    \color{white}\sffamily\bfseries Prioridad &
    \color{white}\sffamily\bfseries Verificación \\
