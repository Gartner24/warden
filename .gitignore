# ---------------------------------------------------------------
# docs/ - keep ONLY LaTeX source (.tex / .sty), drop everything else
# ---------------------------------------------------------------
docs/**
!docs/
!docs/latex/
!docs/latex/*.tex
!docs/latex/*.sty

